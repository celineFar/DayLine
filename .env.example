# Timeline Bot Environment Variables
# Copy this file to .env and fill in your values

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Sheets URL
SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/your_spreadsheet_id/edit

# Path to Google Service Account JSON file (optional, defaults to service_account.json)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Sleep reminder delay in seconds (optional, defaults to 10 hours)
SLEEP_REMINDER_SECONDS=36000
